# Firecrawl self-hosted — OpenRouter + Mac-friendly resources
# Generated by skill: use-firecrawl
# Replace __OPENROUTER_KEY__ with your real key (starts with sk-or-v1-)

OPENROUTER_API_KEY=__OPENROUTER_KEY__

# LLM via OpenRouter (OpenAI-compatible)
OPENAI_API_KEY=${OPENROUTER_API_KEY}
OPENAI_BASE_URL=https://openrouter.ai/api/v1
MODEL_NAME=deepseek/deepseek-v4-pro
# Embeddings via OpenRouter ($0.01/M tokens, multilingual, 33K context)
MODEL_EMBEDDING_NAME=qwen/qwen3-embedding-8b

# ===== Firecrawl core =====
NUM_WORKERS_PER_QUEUE=4
PORT=3002
HOST=0.0.0.0
REDIS_URL=redis://redis:6379
REDIS_RATE_LIMIT_URL=redis://redis:6379
PLAYWRIGHT_MICROSERVICE_URL=http://playwright-service:3000/scrape
USE_DB_AUTHENTICATION=false

# API key for Firecrawl itself (any non-empty value; checked on every request)
TEST_API_KEY=fc-local-dev-key

# ===== Mac-friendly concurrency =====
CRAWL_CONCURRENT_REQUESTS=5
MAX_CONCURRENT_JOBS=2
BROWSER_POOL_SIZE=3

# ===== Optionals (empty = disabled) =====
SEARCHAPI_API_KEY=
SUPABASE_ANON_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_TOKEN=
SCRAPING_BEE_API_KEY=
LLAMAPARSE_API_KEY=
SLACK_WEBHOOK_URL=
POSTHOG_API_KEY=
POSTHOG_HOST=
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Logging
LOGGING_LEVEL=INFO

# Disable paid services
X402_ENABLED=false
